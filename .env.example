# Host port to publish the proxy on.
PORT=3000

# Accounts are addressed in the URL (/<account>/<service>) and authorized in the
# /admin UI — there is no account env var. Add accounts at http://localhost:3000/admin.

# Optional: require `Authorization: Bearer <token>` on every /<account>/<service> call.
# Strongly recommended if the port is reachable beyond localhost.
AUTH_TOKEN=

# Credential admin UI at /admin (upload client_secret.json + per-account OAuth).
# A password is REQUIRED: left blank, every /admin route returns 503.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Loopback base used to build the OAuth redirect URI. Must match how you reach
# the UI in a browser; change the port if you remap the published port.
OAUTH_REDIRECT_BASE=http://localhost:3000
